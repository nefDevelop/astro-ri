---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
const authors = [...new Set(posts.flatMap((p) => p.data.author))].sort();
---

<Layout title="Authors" description="All authors">
	<section class="mx-auto max-w-3xl px-4 py-12">
		<h1 class="mb-2 text-3xl font-bold">Authors</h1>
		<p class="mb-8 text-[var(--text-muted)]">Browse posts by author.</p>

		<div class="flex flex-wrap gap-3">
			{
				authors.map((author) => {
					const count = posts.filter((p) => p.data.author.includes(author)).length;
					return (
						<a
							href={`/authors/${author}/`}
							class="inline-flex items-center gap-2 rounded-full bg-[var(--secondary-90)] px-4 py-2 text-sm font-medium text-[var(--secondary-10)] no-underline transition-colors hover:bg-[var(--secondary-80)]"
						>
							{author}
							<span class="rounded-full bg-[var(--secondary-80)] px-1.5 py-0.5 text-xs">{count}</span>
						</a>
					);
				})
			}
		</div>
	</section>
</Layout>
