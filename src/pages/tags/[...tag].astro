---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

function getHierarchicalTags(tags: string[]): string[] {
	const expanded = new Set<string>();
	tags.forEach((tag) => {
		const parts = tag.split('/');
		let current = '';
		parts.forEach((part, index) => {
			current = index === 0 ? part : `${current}/${part}`;
			expanded.add(current);
		});
	});
	return Array.from(expanded);
}

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const allTags = [...new Set(posts.flatMap((p) => getHierarchicalTags(p.data.tags || [])))];
	return allTags.map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const allPosts = await getCollection('blog');
const posts = allPosts
	.filter((p) => (p.data.tags || []).some((t) => t === tag || t.startsWith(tag + '/')))
	.sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());

---

<Layout title={`#${tag}`} description={`Posts tagged with ${tag}`}>
	<section class="mx-auto max-w-3xl px-4 py-12">
		<div class="mb-8">
			<a href="/tags" class="text-sm text-[var(--primary)] no-underline hover:underline">&larr; All tags</a>
			<h1 class="mt-2 text-3xl font-bold">#{tag}</h1>
			<p class="text-[var(--text-muted)]">{posts.length} post(s)</p>
		</div>

		<div class="space-y-6">
			{
				posts.map((post) => (
					<article class="rounded-xl border border-[var(--border-light)] bg-[var(--card-bg)] p-5">
						<a href={`/blog/${post.id}/`} class="no-underline">
							<h2 class="text-lg font-semibold text-[var(--text-main)] hover:text-[var(--primary)]">
								{post.data.title}
							</h2>
						</a>
						<p class="mt-1 text-sm text-[var(--text-muted)]">{post.data.description}</p>
						<div class="mt-2 text-xs text-[var(--text-muted)]">
							<FormattedDate date={post.data.published} />
						</div>
					</article>
				))
			}
		</div>
	</section>
</Layout>
