---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="mx-auto max-w-5xl px-4 py-12">
		<div class="mb-12 text-center">
			<h1 class="text-4xl font-bold tracking-tight md:text-5xl">{SITE_TITLE}</h1>
			<p class="mt-2 text-lg text-[var(--text-muted)]">{SITE_DESCRIPTION}</p>
		</div>

		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{
				posts.map((post) => (
					<article class="group rounded-xl border border-[var(--border-light)] bg-[var(--card-bg)] transition-shadow hover:shadow-sm">
						<a href={`/blog/${post.id}/`} class="block p-5 no-underline">
							<h2 class="text-lg font-semibold leading-snug text-[var(--text-main)] group-hover:text-[var(--primary)]">
								{post.data.title}
							</h2>
							<p class="mt-2 line-clamp-2 text-sm text-[var(--text-muted)]">
								{post.data.description}
							</p>
							<div class="mt-3 flex items-center gap-2 text-xs text-[var(--text-muted)]">
								<FormattedDate date={post.data.pubDate} />
								<span>&middot;</span>
								<span class="rounded-full bg-[var(--primary-90)] px-1.5 py-0.5 text-[10px] text-[var(--primary-10)]">
									{post.data.category}
								</span>
							</div>
							{
								post.data.tags.length > 0 && (
									<div class="mt-2 flex flex-wrap gap-1.5">
										{post.data.tags.slice(0, 3).map((tag) => (
											<span class="rounded-full bg-[var(--tertiary-90)] px-2 py-0.5 text-[10px] text-[var(--tertiary-10)]">
												#{tag}
											</span>
										))}
									</div>
								)
							}
						</a>
					</article>
				))
			}
		</div>
	</section>
</Layout>
