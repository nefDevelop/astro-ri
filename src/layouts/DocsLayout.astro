---
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';

interface Props {
	title: string;
	description: string;
	entries: CollectionEntry<'docs'>[];
}
const { title, description, entries } = Astro.props;

const sections = [...new Set(entries.map((e) => e.data.section))];
---

<Layout title={title} description={description}>
	<div class="mx-auto flex max-w-6xl px-4 py-8">
		<aside class="hidden w-56 shrink-0 md:block">
		<nav class="sticky top-20 space-y-6">
				{
					sections.map((section) => (
						<div>
							<h3 class="mb-2 text-xs font-bold uppercase tracking-widest text-[var(--text-muted)]">
								{section}
							</h3>
							<ul class="space-y-1">
								{
									entries
										.filter((e) => e.data.section === section)
										.sort((a, b) => a.data.order - b.data.order)
										.map((entry) => (
											<li>
												<a
													href={`/docs/${entry.id}/`}
													class="block rounded-md px-3 py-1.5 text-sm text-[var(--text-muted)] no-underline hover:bg-[var(--border-light)] hover:text-[var(--text-main)]"
												>
													{entry.data.title}
												</a>
											</li>
										))
								}
							</ul>
						</div>
					))
				}
			</nav>
		</aside>

		<article class="min-w-0 flex-1 md:pl-10">
			<slot />
		</article>
	</div>
</Layout>
