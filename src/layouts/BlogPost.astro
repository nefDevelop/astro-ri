---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import FloatingTOC from '../components/FloatingTOC.astro';
import Layout from './Layout.astro';

type Props = CollectionEntry<'blog'>['data'] & { readingTime?: { text: string } };

const {
	title, description, published, updated, image,
	tags = [], categories = [], author = [],
	difficulty, readingTime,
} = Astro.props;
---

<Layout title={title} description={description}>
	<div class="mx-auto max-w-6xl px-4 py-8">
		<div class="flex gap-8">
			<article class="min-w-0 flex-1">
				{
					image && (
						<div class="mb-8 overflow-hidden rounded-xl">
							<img src={image} alt="" class="size-full object-cover" />
						</div>
					)
				}

				<header class="mb-8">
					<div class="mb-2 flex flex-wrap items-center gap-2 text-sm text-[var(--text-muted)]">
						<FormattedDate date={published} />
						{categories.length > 0 && (
							<>
								<span>&middot;</span>
								<span class="rounded-full bg-[var(--primary-90)] px-2 py-0.5 text-xs text-[var(--primary-10)]">
									{categories[0]}
								</span>
							</>
						)}
						{difficulty && (
							<>
								<span>&middot;</span>
								<span class="capitalize">{difficulty}</span>
							</>
						)}
						{readingTime?.text && (
							<>
								<span>&middot;</span>
								<span>{readingTime.text}</span>
							</>
						)}
						{updated && (
							<>
								<span>&middot;</span>
								<span class="italic">Updated <FormattedDate date={updated} /></span>
							</>
						)}
					</div>
					<h1 class="text-3xl font-bold leading-tight tracking-tight md:text-4xl">{title}</h1>
					<p class="mt-2 text-lg text-[var(--text-muted)]">{description}</p>
					{author.length > 0 && (
						<p class="mt-1 text-sm text-[var(--text-muted)]">By {author.join(', ')}</p>
					)}
					{
						tags.length > 0 && (
							<div class="mt-4 flex flex-wrap gap-2">
								{tags.map((tag) => (
									<a
										href={`/tags/${tag}/`}
										class="rounded-full bg-[var(--tertiary-90)] px-3 py-1 text-xs font-medium text-[var(--tertiary-10)] no-underline transition-colors hover:bg-[var(--tertiary-80)]"
									>
										#{tag}
									</a>
								))}
							</div>
						)
					}
				</header>

				<div class="prose">
					<slot />
				</div>
			</article>

			<FloatingTOC class="w-56 shrink-0" />
		</div>
	</div>
</Layout>
