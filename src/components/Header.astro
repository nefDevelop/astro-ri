---
import { SITE_TITLE } from '../consts';
import Sun from './icons/Sun.astro';
import Moon from './icons/Moon.astro';
import Menu from './icons/Menu.astro';
---

<header
	x-data="{ mobileOpen: false, dark: document.documentElement.classList.contains('dark') }"
	transition:name="header"
	transition:persist
	class="fixed inset-x-0 bottom-0 z-50 border-t border-[var(--border-light)] bg-[var(--card-bg)]/80 backdrop-blur-sm supports-[backdrop-filter]:bg-[var(--card-bg)]/60 md:sticky md:top-0 md:border-t-0 md:border-b"
>
	<div x-show="mobileOpen" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0" class="border-b border-[var(--border-light)] bg-[var(--card-bg)] px-4 py-3 md:hidden">
		<div class="flex flex-col gap-2">
			<a href="/" class="rounded-md px-3 py-2 text-sm font-medium text-[var(--text-muted)] no-underline hover:bg-[var(--border-light)] hover:text-[var(--primary)]">Home</a>
			<a href="/blog" class="rounded-md px-3 py-2 text-sm font-medium text-[var(--text-muted)] no-underline hover:bg-[var(--border-light)] hover:text-[var(--primary)]">Blog</a>
			<a href="/docs" class="rounded-md px-3 py-2 text-sm font-medium text-[var(--text-muted)] no-underline hover:bg-[var(--border-light)] hover:text-[var(--primary)]">Docs</a>
			<a href="/search" class="rounded-md px-3 py-2 text-sm font-medium text-[var(--text-muted)] no-underline hover:bg-[var(--border-light)] hover:text-[var(--primary)]">Search</a>
			<a href="/archive" class="rounded-md px-3 py-2 text-sm font-medium text-[var(--text-muted)] no-underline hover:bg-[var(--border-light)] hover:text-[var(--primary)]">Archive</a>
			<a href="/about" class="rounded-md px-3 py-2 text-sm font-medium text-[var(--text-muted)] no-underline hover:bg-[var(--border-light)] hover:text-[var(--primary)]">About</a>
		</div>
	</div>

	<nav class="flex w-full items-center justify-between px-4 py-3 md:px-8">
		<a href="/" class="text-lg font-bold tracking-tight no-underline text-[var(--text-main)] hover:text-[var(--primary)]">
			{SITE_TITLE}
		</a>

		<div class="hidden items-center gap-6 md:flex">
			<a href="/" class="text-sm font-medium text-[var(--text-muted)] no-underline hover:text-[var(--primary)]">Home</a>
			<a href="/blog" class="text-sm font-medium text-[var(--text-muted)] no-underline hover:text-[var(--primary)]">Blog</a>
			<a href="/docs" class="text-sm font-medium text-[var(--text-muted)] no-underline hover:text-[var(--primary)]">Docs</a>
			<a href="/tags" class="text-sm font-medium text-[var(--text-muted)] no-underline hover:text-[var(--primary)]">Tags</a>
			<a href="/categories" class="text-sm font-medium text-[var(--text-muted)] no-underline hover:text-[var(--primary)]">Categories</a>
			<a href="/search" class="text-sm font-medium text-[var(--text-muted)] no-underline hover:text-[var(--primary)]">Search</a>
			<a href="/archive" class="text-sm font-medium text-[var(--text-muted)] no-underline hover:text-[var(--primary)]">Archive</a>
			<a href="/about" class="text-sm font-medium text-[var(--text-muted)] no-underline hover:text-[var(--primary)]">About</a>
		</div>

		<div class="flex items-center gap-3">
			<button
				@click="
					dark = !dark;
					document.documentElement.classList.toggle('dark', dark);
					document.documentElement.dataset.theme = dark ? 'github-dark' : 'github-light';
					localStorage.setItem('theme', dark ? 'dark' : 'light')
				"
				class="flex size-8 cursor-pointer items-center justify-center rounded-md text-[var(--text-muted)] hover:bg-[var(--border-light)] hover:text-[var(--text-main)]"
				aria-label="Toggle dark mode"
			>
				<Moon x-show="!dark" />
				<Sun x-show="dark" />
			</button>

			<button
				x-on:click="mobileOpen = !mobileOpen"
				class="flex size-8 cursor-pointer items-center justify-center rounded-md text-[var(--text-muted)] hover:bg-[var(--border-light)] hover:text-[var(--text-main)] md:hidden"
				aria-label="Toggle menu"
			>
				<Menu />
			</button>
		</div>
	</nav>
</header>
