---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About" description="About this site">
	<section class="mx-auto max-w-3xl px-4 py-12">
		<h1 class="mb-4 text-3xl font-bold">About</h1>
		<p class="mb-6 text-lg text-[var(--text-muted)]">This is the Ri theme for Astro.</p>

		<p class="mb-4">
			A theme for blog and documentation, with a generative color system that adapts from a single seed color.
		</p>
	</section>
</Layout>
