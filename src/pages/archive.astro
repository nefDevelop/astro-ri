---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());

const years = [...new Set(posts.map((p) => p.data.published.getFullYear()))].sort((a, b) => b - a);
---

<Layout title="Archive" description="All posts">
	<section class="mx-auto max-w-3xl px-4 py-12">
		<h1 class="mb-2 text-3xl font-bold">Archive</h1>
		<p class="mb-8 text-[var(--text-muted)]">All posts in chronological order.</p>

		{
			years.map((year) => (
				<div class="mb-10">
					<h2 class="mb-4 text-2xl font-bold text-[var(--primary)]">{year}</h2>
					<div class="space-y-4">
						{
							posts
								.filter((p) => p.data.published.getFullYear() === year)
								.map((post) => (
									<div class="flex items-baseline gap-4">
										<span class="shrink-0 text-sm tabular-nums text-[var(--text-muted)]">
											<FormattedDate date={post.data.published} />
										</span>
										<a
											href={`/blog/${post.id}/`}
											class="text-[var(--text-main)] no-underline hover:text-[var(--primary)]"
										>
											{post.data.title}
										</a>
									</div>
								))
						}
					</div>
				</div>
			))
		}
	</section>
</Layout>
