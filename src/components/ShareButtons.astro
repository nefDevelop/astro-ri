---
// ShareButtons.astro - Social sharing links and copy URL button
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<div x-data="{ copied: false }" class="share-buttons mt-8 flex flex-wrap items-center gap-3 border-t border-[var(--border-light)] pt-6">
	<span class="text-sm font-medium text-[var(--text-muted)]">Compartir:</span>
	<div class="flex items-center gap-2">
		<!-- Twitter / X -->
		<a
			href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`}
			target="_blank"
			rel="noopener noreferrer"
			class="flex size-9 items-center justify-center rounded-md border border-[var(--border-light)] bg-[var(--card-bg)] text-[var(--text-muted)] hover:border-[var(--primary)] hover:text-[var(--primary)] transition-colors"
			title="Compartir en Twitter/X"
		>
			<svg class="size-4 fill-current" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
		</a>

		<!-- LinkedIn -->
		<a
			href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
			target="_blank"
			rel="noopener noreferrer"
			class="flex size-9 items-center justify-center rounded-md border border-[var(--border-light)] bg-[var(--card-bg)] text-[var(--text-muted)] hover:border-[var(--primary)] hover:text-[var(--primary)] transition-colors"
			title="Compartir en LinkedIn"
		>
			<svg class="size-4 fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
		</a>

		<!-- Copiar Enlace -->
		<button
			@click={`
				navigator.clipboard.writeText(window.location.href);
				copied = true;
				setTimeout(() => copied = false, 2000);
			`}
			class="flex h-9 items-center gap-1.5 rounded-md border border-[var(--border-light)] bg-[var(--card-bg)] px-3 text-sm text-[var(--text-muted)] hover:border-[var(--primary)] hover:text-[var(--primary)] transition-colors cursor-pointer"
			:class="copied ? 'border-[var(--primary)] text-[var(--primary)]' : ''"
			title="Copiar enlace"
		>
			<svg x-show="!copied" class="size-4 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" /></svg>
			<svg x-show="copied" x-cloak class="size-4 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-d="M4.5 12.75l6 6 9-13.5" d="M4.5 12.75l6 6 9-13.5" /></svg>
			<span x-text="copied ? '¡Copiado!' : 'Copiar enlace'">Copiar enlace</span>
		</button>
	</div>
</div>
